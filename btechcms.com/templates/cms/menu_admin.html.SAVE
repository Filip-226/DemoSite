	    function print_data() {
	        var print_data_str = $("#1500Form").serialize();
	        var print_data_arr = print_data_str.split('&');
	        var arr = [];
	        for(var i = 0; i < print_data_arr.length; i ++) {
	            var aa = print_data_arr[i].split('=');
	            var obj = {};
	            if(aa[1].includes("%20")) {
	                aa[1] = aa[1].replace(/%20/g, "  ");
	            } else {
	                aa[1] = aa[1];
	            }
	            obj[aa[0]] = aa[1];
	            arr.push(obj)
	        }
	        var datas;
	        var str = '';
            datas = print_style(arr, str);
	        setTimeout(function() {
	            console.log(arr[3].patient_lname)
	            w=window.open();
                w.document.write(datas);
                w.print();
                w.close();
	        }, 3000);
