		function fdp(e) { return document.getElementById(e); }
		function loadClientInfo(id) {
			$.ajax({
				url: 'ajax/getClientData.html',
				method: 'POST',
				data: {
					client: id
				},
				success: function(res) {
					var d = JSON.parse(res).data;
					fdp('insured_id').value = d.insured_id;
					fdp('pFN').value = d.firstname;
					fdp('pLN').value = d.lastname;
					fdp('pADDR').value = d.address;
					fdp('pCITY').value = d.city;
					fdp('pZIP').value = d.zip;
					fdp('pSTATE').value = d.state;
					fdp('pPHONE').value = d.phone;
					$("#1500Form").submit(function(e) {

						var url = "insert_cmsdata.php"; // the script where you handle the form input.
						//var mybutval = $("input[type=submit][clicked=true]").val();
						//alert(mybutval.name);
						// Get the button that was clicked   
						//var butname = $(this.id).context.activeElement;

						// You can get its name like this
						//alert(butname.name);

						$.ajax({
							type: "POST",
							url: url,
							data: $("#1500Form").serialize(), 
							success: function(data)
							{
								if(data=='inserted') {
									alert('Client CMS Data Added Successfully.');
									location.reload();
								}
								else {
									alert('somthing went wrong please try again later' );
								}
								console.log(data); // show response from the php script.
							}
						});

						e.preventDefault(); // avoid to execute the actual submit of the form.
					});
				},
				error: function(e) {
					console.error(e);
				}
			});
		}
		function fileClaim(id) {
			$("#newClaimModal").modal('hide');
			$("#claimFormModal").modal('show');
			loadClientInfo(id);
		}

	</script>