	<!-- Left Sidebar End -->
	<!-- New Claim Modal -->
	<div class="modal fade" id="newClaimModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
		<div class="modal-dialog" role="document">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title" id="exampleModalLabel">File a new Claim</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
					<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<table id="clientList"
						data-toggle="table"
						data-search="true"
						data-sort-name="id"
						data-page-list="[5, 10, 20]"
						data-page-size="10"
						data-pagination="true"
						class="table-bordered ">
						<thead>
							<tr>
								<th data-field="id" data-sortable="true">ID</th>
								<th data-field="firstname" data-sortable="true">First Name</th>
								<th data-field="lastname" data-sortable="true">Last Name</th>
								<th data-field="insured_id" data-sortable="true">Insured ID</th>
							</tr>
						</thead>
						<tbody id="clientListTBody">
							<:tr tid="clientlist"><td><a href="javascript:void(0)" onclick="fileClaim({ID})">{ID}</a></td><td><a href="javascript:void(0)" onclick="fileClaim({ID})">{FIRSTNAME}</a></td><td><a href="javascript:void(0)" onclick="fileClaim({ID})">{LASTNAME}</a></td><tr:>
						</tbody>
					</table>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
				</div>
			</div>
		</div>
	</div>
	<!-- Claim Form Modal -->

	<!-- New PRINT CMS 1500 Form  Modal -->
	<div class="modal fade" id="printCMS1500Form" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
		<div class="modal-dialog" role="document">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title" id="exampleModalLabel">Print CMS 1500 Form</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
					<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<table id="clientList"
						data-toggle="table"
						data-search="true"
						data-sort-name="id"
						data-page-list="[5, 10, 20]"
						data-page-size="10"
						data-pagination="true"
						class="table-bordered ">
						<thead>
							<tr>
								<th data-field="id" data-sortable="true">ID</th>
								<th data-field="firstname" data-sortable="true">First Name</th>
								<th data-field="lastname" data-sortable="true">Last Name</th>
								<th data-field="insured_id" data-sortable="true">Insured ID</th>
							</tr>
						</thead>
						<tbody id="clientListTBody">
							<:tr tid="clientlist"><td><a href="javascript:void(0)" onclick="fileClaim({ID})">{ID}</a></td><td><a href="javascript:void(0)" onclick="fileClaim({ID})">{FIRSTNAME}</a></td><td><a href="javascript:void(0)" onclick="fileClaim({ID})">{LASTNAME}</a></td><tr:>
						</tbody>
					</table>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-primary" data-dismiss="modal">Print</button>
					<button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
				
				</div>
			</div>
		</div>
	</div>
	<!-- PRINT CMS 1500 Form  Modal -->

	<div id="claimFormModal" class="modal fade" style="overflow-y: scroll">
		<div class="modal-dialog">
			<div class="modal-content"  style="left: -350px; width:1200px;" id="print_content">
				<div class="modal-header">  
					<button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
				</div>
				<div class="modal-body">
					<h4 class="header-title m-t-0">&nbsp;&nbsp;&nbsp;&nbsp;Client Entry Form</h4>
					<form id="1500Form" action="#">
						<input type="hidden" name="command" value="cms1500SaveData">
						<div class="table-responsive">
							<style>
								#table > thead > tr > th, .table > tbody > tr > th, .table > tfoot > tr > th, .table > thead > tr > td, .table > tbody > tr > td, .table > tfoot > tr > td, .table > thead > tr > th, .table-bordered {
								border-top: 1px solid #000;						
								}
								.cus-chkbx{
								text-align: center;
								}   
								.checkbox label{
								font-size: 10px;
								}
								@media (min-width: 767px){
								.cus-chkbx{
								float: left;
								/* margin: 2px 6px; */
								}
								}
							</style>
							&nbsp; &nbsp;
							<table border="1" class="#table" width="100%">
								<tr>
									<td style="border-right:none;" >
										
											<div style="margin-right: 5px;" class="cus-chkbx"> <b>1.</b> </div>
											<div class="cus-chkbx"> Medicare<br>
												<input id="checkbox_medicare" type="checkbox">
												<label for="checkbox_medicare"> (Medicare#) </label>
											</div>
											<div class="cus-chkbx"> Medicad<br>
												<input id="checkbox_medicaid" type="checkbox">
												<label for="checkbox_medicaid"> (Medicaid#) </label>
											</div>
											<div class="cus-chkbx"> TR/CARE<br>
												<input id="checkbox_tricare" type="checkbox">
												<label for="checkbox_tricare"> (ID#/DoD#) </label> <br><br>
											</div>
											<div class="cus-chkbx"> CHAMPVA <br>
												<input id="checkbox_champva" type="checkbox">
												<label for="checkbox_champva"> (Member ID#) </label>
											</div>
											<div class="cus-chkbx"> GROUP <br/>&nbsp;&nbsp; HEALTH PLAN <br>
												<input id="checkbox_groupplan" type="checkbox">
												<label for="checkbox_groupplan"> (ID#) </label>
											</div>
											<div class="cus-chkbx"> FECA <br/>&nbsp;&nbsp;BLKLUNG <br>
												<input id="checkbox_feca" type="checkbox">
												<label for="checkbox_feca"> (ID#) </label>
											</div>
											<div class="cus-chkbx"> OTHER<br>
												<input id="checkbox_other" type="checkbox">
												<label for="checkbox_other"> (ID#) </label>
											</div>
										</div>
									</td>
									<td  >
										<div ><b>1a.</b>
											<label for="" style="text-align:left"> INSURED I.D. NUMBER<span class="text-danger">*</span></label>
											<span for="" style="float:right;margin-right:5px;">(For program in Item 1)</span><br>
											<input type="text" class="form-control" value="" required="" name="insured_id" id="insured_id">
											<input type="hidden" name="uniqueid" value="1">
										</div>
									</td>
								</tr>
								<tr>
									<td>
										<table>
											<tr>
												<td >
													<div>
														<label for="clientinfo">2. PATIENTS NAME (Last Name, First Name,<br> Middle Initial)<span class="text-danger">*</span></label>
														<input type="text" name="patient_lname" parsley-trigger="change" value="" id="pLN" required placeholder="Enter Lastname" class="form-control" id="userName">
														<input type="text" name="patient_fname" parsley-trigger="change" value="" id="pFN" required placeholder="Enter First Name" class="form-control" id="firstName">
													</div>
												</td>
												<td>
													<table class="">
														<tr>
															<td style="padding-left:7px;">
																<label for="clientinfo"> 3. PATIENTS BIRTH DATE<span class="text-danger">*</span></label>
																<input type="date" name="patientDOB" required=""  value="" id="patient_dob" class="form-control"   pattern="(?:19|20)[0-9]{2}-(?:(?:0[1-9]|1[0-2])/(?:0[1-9]|1[0-9]|2[0-9])|(?:(?!02)(?:0[1-9]|1[0-2])/(?:30))|(?:(?:0[13578]|1[02])-31))">
																<script>
																	(function () {
																	var date = '01 17 2018',
																	field = document.querySelector('#patient_dob');
																	field.value = date;
																	console.log(field.value);
																	
																	})()
																</script>
															</td>
															<td style="padding-left:7px;">
																<label for="clientinfo"> SEX<span class="text-danger">*</span></label>
																<select style="padding:0px;font-size: 12px;" class="form-control" name="patientSex">
																	<option SELECTED value="M">M</option>
																	<option  value="F">F</option>
																</select>
															</td>
														</tr>
													</table>
												</td>
											</tr>
										</table>
									</td>patient_signed
									<td >
										<div  class="form-group">
											<label for="clientinfo">4. INSUREDS NAME (Last Name, First Name, Middle Initial)<span class="text-danger">*</span></label>
											<input type="text" name="insured_lname" parsley-trigger="change" required="" value="" placeholder="Enter Lastname,Firstname" class="form-control" id="insuredLN">
										</div>
									</td>
								</tr>
								<tr>
									<td>
										<table>
											<tr>
												<td>
													<div class="form-group">
														<label for="clientinfo">5. PATIENTS ADDRESS<span class="text-danger">*</span></label>
														<input type="text" name="patientAddress" required="" placeholder="PATIENTS ADDRESS" id="pADDR" value="ghghgfh" class="form-control">
													</div>
												</td>
												<td style="padding-left:7px;">
													<div class="form-group">
														<label for="clientinfo">6. PATIENT RELATIONSHIP TO INSURED<span class="text-danger">*</span></label>
														<select class="form-control" id="patient_relationship">
															<option value="SELF">SELF</option>
															<option value="SPOUSE">SPOUSE</option>
															<option value="CHILD">CHILD</option>
															<option value="OTHER">OTHER</option>
														</select>
													</div>
												</td>
											</tr>
										</table>
									</td>
									<td >
										<div float:left;="" class="form-group">
											<label for="clientinfo">7. INSUREDS ADDRESS (No. Street)<span class="text-danger">*</span></label>
											<input type="text" name="insuredAddress" required="" placeholder="INSURED's ADDRESS" id="insuredADDR" value="" class="form-control">
										</div>
									</td>
								</tr>
								<tr>
									<td>
										<table>
											<tr>
												<td>
													<table >
														<tr>
															<td style="padding:3px;"><label >CITY<span class="text-danger">*</span></label>
																<input type="text" name="patientCity" required="" value="" id="pCITY" placeholder="CITY" class="form-control">
															</td>
															<td style="padding:3px;"><label>STATE<span class="text-danger">*</span></label>
																<input type="text" name="patientState" required="" value="fdg" id="pSTATE" placeholder="STATE" class="form-control">
															</td>
														</tr>
														<tr>
															<td style="padding:3px;"><label >ZIP CODE<span class="text-danger">*</span></label>
																<input type="text" name="patientZip" required="" value="" id="pZIP" placeholder="ZIP CODE" class="form-control">
															</td>
															<td style="padding:3px;"><label>TELEPHONE<span class="text-danger">*</span></label>
																<input type="text" name="patientPhone" required="" value="" id="pPHONE" placeholder="TELEPHONE" class="form-control">
															</td>
														</tr>
													</table>
												</td>
												<td style="padding:3px;">
													<div class="form-group"><label for="userName">8. RESERVED FOR NUCC USE<span class="text-danger">*</span></label>
														<textarea readonly="" class="form-control"></textarea>
													</div>
												</td>
											</tr>
										</table>
									</td>
									<td >
										<table >
											<tr>
												<td style="padding:3px;"><label >CITY<span class="text-danger"></span></label>
													<input type="text" id="insuredCITY" name="insured_CITY" placeholder="CITY" value="" class="form-control">
												</td>
												<td style="padding:3px;"><label>STATE<span class="text-danger"></span></label>
													<input type="text" id="insuredSTATE" name="insured_STATE" placeholder="STATE" value="" class="form-control">
												</td>
											</tr>
											<tr>
												<td style="padding:3px;"><label >ZIP CODE<span class="text-danger"></span></label>
													<input type="text" required="" id="insuredZIP" name="insured_ZIP" placeholder="ZIP CODE" value="" class="form-control">
												</td>
												<td style="padding:3px;"><label>TELEPHONE<span class="text-danger"></span></label>
													<input type="text" id="insuredPHONE" name="insured_PHONE" placeholder="TELEPHONE" value="" class="form-control">
												</td>
