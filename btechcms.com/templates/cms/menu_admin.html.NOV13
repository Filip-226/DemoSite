	<script>
       
	    //2019-10-29 Programmer Joseph
	    console.log('My work')
	    var print_btn = document.getElementById('print_btn');
	    print_btn.addEventListener('click', print_data);
	    function print_data() {
	         $("input[type=date]").datepicker({
              dateFormat: 'mm-dd-yyyy'
            });

	        var print_data_str = $("#1500Form").serialize();
	        var print_data_arr = print_data_str.split('&');
	        var arr = [];
	        for(var i = 0; i < print_data_arr.length; i ++) {
	            var aa = print_data_arr[i].split('=');
	            var obj = {};
	            if(aa[1].includes("%20")) {
	                aa[1] = aa[1].replace(/%20/g, "  ");
	            } else {
	                aa[1] = aa[1];
	            }
	            obj[aa[0]] = aa[1];
	            arr.push(obj)
	        }
	        var datas;
	        var str = '';
            datas = print_style(arr, str);
	        setTimeout(function() {
	            w=window.open();
                w.document.write(datas);
                w.print();
                w.close();
	        }, 3000);
	        function print_style(data_arr, printContents) {
	            console.log(data_arr)
                var first_check = ($('#checkbox_medicare').prop('checked') == true)?"":"none";
                var second_check = ($('#checkbox_medicaid').prop('checked') == true)?"":"none";
                var third_check = ($('#checkbox_tricare').prop('checked') == true)?"":"none";
                var forth_check = ($('#checkbox_champva').prop('checked') == true)?"":"none";
                var fifth_check = ($('#checkbox_groupplan').prop('checked') == true)?"":"none";
                var sixth_check = ($('#checkbox_feca').prop('checked') == true)?"":"none";
                var seventh_check = ($('#checkbox_other').prop('checked') == true)?"":"none";
                printContents += '<style>';
                printContents += '#divREDPrint div>a {'
                printContents += 'z-index: 200;'
                printContents += '}'
                printContents += '</style>'
                printContents += '<div id="divREDPrint" style="width: 1600px" >'	                   	
                printContents += '<div style="color:#0000FF;left:30px">'
                printContents += '<a style="font-size:18px;;position:absolute;left:12px;top:120px; display:'+first_check+'">X</a>'
                printContents += '<a style="font-size:18px;position:absolute;left:46px;top:120px; display:'+second_check+'">X</a>'
                printContents += '<a style="font-size:18px;position:absolute;left:291px;top:120px; display:'+third_check+'">X</a>'
                printContents += '<a style="font-size:18px;position:absolute;left:471px;top:120px; display:'+forth_check+'">X</a>'
                printContents += '<a style="font-size:18px;position:absolute;left:611px;top:120px; display:'+fifth_check+'">X</a>'
                printContents += '<a style="font-size:18px;position:absolute;left:771px;top:120px; display:'+sixth_check+'">X</a>'
                printContents += '<a style="font-size:18px;position:absolute;left:891px;top:120px; display:'+seventh_check+'">X</a>'
                
                //--------------------------------------------  INSURED ID   NUMBER    ------------------------------------------------
                //printContents += '<a style="font-size:18px;position:absolute;left:730px;top:157px">'+$('[name=insuredID]').val()+'</a>'
                printContents += '<a style="font-size:18px;position:absolute;left:730px;top:157px">'+$('[name=insured_id]').val()+'</a>'
                
                //--------------------------------------------------------------------------------------------------------------------
                printContents += '<a style="font-size:18px;position:absolute;left:13px;top:195px">'+data_arr[3].patient_lname +","+' '+data_arr[4].patient_fname+'</a>'
                //------------------------------------------------------------------------------------------------------------------------
                
                //-----------------------------------------------------------------------------------------------------------------------
                var insured_lname = data_arr[7].insured_lname;
                if(insured_lname == undefined) {
                    insured_lname = '';
                } else {
                    insured_lname = insured_lname.replace('%2C', ' ');
                }
                printContents += '<a style="font-size:18px;position:absolute;left:700px;top:195px">'+insured_lname+' </a>'
                //-----------------------------------------------------------------------------------------------------------------------
                
                //printContents += '<a style="font-size:18px;position:absolute;left:15px;top:228px">'+data_arr[8].patientAddress+'</a>' 
                printContents += '<a style="font-size:18px;position:absolute;left:13px;top:243px">'+data_arr[8].patientAddress+'</a>' 
                //-------------------------------------------------------------------------------------------------------------------------
                console.log(data_arr)
                
                //----------------------------------------------------- PATIENT  DOB   ----------------------------------------------------
                var birthdate = data_arr[5].patientDOB;
                if(birthdate == undefined) {
                    printContents += '<a style="font-size:18px;position:absolute;left:436px;top:204px"></a>' 
                    printContents += '<a style="font-size:18px;position:absolute;left:479px;top:204px"></a>'
                    printContents += '<a style="font-size:18px;position:absolute;left:508px;top:204px"></a>'
                } else {
                    printContents += '<a style="font-size:18px;position:absolute;left:436px;top:204px">'+birthdate.slice(5, 7)+'</a>' 
                    printContents += '<a style="font-size:18px;position:absolute;left:479px;top:204px">'+birthdate.slice(8, 10)+'</a>'
                    printContents += '<a style="font-size:18px;position:absolute;left:508px;top:204px">'+birthdate.slice(2, 4)+'</a>'
                }
                if(data_arr[6].patientSex == 'M') {
                    printContents += '<a style="font-size:18px;position:absolute;left:591px;top:203px">X</a>'
                } else {
                    printContents += '<a style="font-size:18px;position:absolute;left:647px;top:203px">X</a>'
                }
                
               
                var patient_relationship = $("#patient_relationship option:selected").val();
                //if(patient_relationship == 'SELF')
                //    printContents += '<a style="font-size:18px;position:absolute;left:640px;top:200px">X</a>'
                //if(patient_relationship == 'SPOUSE')
                //    printContents += '<a style="font-size:18px;position:absolute;left:740px;top:200px">X</a>'
                //if(patient_relationship == 'CHILD')
                //    printContents += '<a style="font-size:18px;position:absolute;left:820px;top:200px">X</a>'
                //if(patient_relationship == 'OTHER')
                //    printContents += '<a style="font-size:18px;position:absolute;left:920px;top:200px">X</a>'
                    
                //---------------------------------------------------------------------------------------------------------------------------
                printContents += '<a style="font-size:18px;position:absolute;left:700px;top:247px">'+data_arr[9].insuredAddress+'</a>'
                //---------------------------------------------------------------------------------------------------------------------------
                
                printContents += '<a style="font-size:18px;;position:absolute;left:6px;top:293px">'+data_arr[10].patientCity+'</a>'
                
                //--------------------------------------------------------------------------------------------------------------------------
                printContents += '<a style="font-size:18px;position:absolute;left:368px;top:296px">'+data_arr[11].patientState+'</a>'
